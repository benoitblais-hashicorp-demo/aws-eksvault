{
    "folders": [
        {
            "path": "."
        }
    ],
    "settings": {
        "files.associations": {
            "*.tfcomponent.hcl": "terraform",
            "*.tfdeploy.hcl": "terraform"
        },
        "editor.formatOnSave": true,
        "[terraform]": {
            "editor.defaultFormatter": "hashicorp.terraform"
        },
        "[hcl]": {
            "editor.defaultFormatter": "hashicorp.terraform"
        },
        "files.exclude": {
            "**/.terraform": true,
            "**/.terraform/*": true
        },
        "search.exclude": {
            "**/.terraform": true
        }
    },
    "extensions": {
        "recommendations": [
            "hashicorp.terraform",
            "DavidAnson.vscode-markdownlint",
            "redhat.vscode-yaml",
            "github.copilot",
            "github.copilot-chat"
        ]
    }
}